---
console.log("javascript")
---

<!-- Header with Search Section -->
<div class="bg-gradient-to-r from-blue-600 to-blue-400 text-white relative max-w-5xl mx-auto min-h-[230px] " style="border-radius: 5px;">
  <!-- Header Content -->
  <div class="text-center py-6 px-7 ">
    <div class="flex items-center justify-center mb-6 w-800px">
      <div class="text-4xl mr-3">📦</div>
      <h1 class="text-4xl font-bold bottom-50">Casillero Digital</h1>
    </div>
    <p class="text-l opacity-90">
      Encuentra productos internacionales con las mejores<br>
      recomendaciones
    </p>
  </div>
  

  <div class="absolute pb-16 w-full bottom-0 left-0 right-0 top-50">
    <div class="max-w-4xl mx-auto px-8">
      <div class="bg-white rounded-2xl shadow-xl p-8 transform -translate-y-8">
        <h2 class="text-gray-700 text-xl font-semibold text-center mb-6">
          ¿Qué producto deseas buscar?
        </h2>
        
        <div class="flex gap-4">
          <input 
            type="text" 
            placeholder="Escribe el nombre del producto que deseas buscar..."
            class="flex-1 px-6 py-4 border border-gray-200 rounded-xl text-gray-700 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          />
          <button class="bg-blue-800 hover:bg-blue-900 text-white font-semibold px-8 py-4 rounded-xl transition-colors duration-200">
            Buscar
          </button>
        </div>
      </div>
    </div>
  </div>
</div>